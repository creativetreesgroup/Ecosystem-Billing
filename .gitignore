# Runtime state generated by docker-compose.devices.yml — config/passwordfile
# stays local per-outlet, never checked in (see mosquitto.conf comments).
/docker/home-assistant/config/*
!/docker/home-assistant/config/.gitkeep
/docker/mosquitto/data/*
!/docker/mosquitto/data/.gitkeep
/docker/mosquitto/log/*
!/docker/mosquitto/log/.gitkeep
/docker/mosquitto/config/passwordfile
